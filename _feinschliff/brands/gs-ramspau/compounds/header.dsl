# gs-ramspau header — bespoke "GRUNDSCHULE / RAMSPAU" wordmark top-left,
# optional pgmeta top-right. No gem icon (the school has no logo mark).

compound header(pgmeta):
  text 120,80  style:wordmark color:black maxwidth:420 maxheight:92 "GRUNDSCHULE\nRAMSPAU"
  text 1100,90 style:pgmeta   maxwidth:720 maxheight:32              "{{ pgmeta }}" align:right
