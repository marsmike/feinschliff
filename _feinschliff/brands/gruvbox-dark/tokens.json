{
  "$schema": "https://schemas.designtokens.org/draft-2/format.json",
  "$description": "Gruvbox Dark \u2014 Retro groove warm palette \u2014 soft brown surfaces and muted earthtone accents. Upstream morhetz/gruvbox (MIT).",
  "color": {
    "$type": "color",
    "accent": {
      "$value": "#FABD2F",
      "$description": "Primary gold \u2014 the only accent. Use sparingly."
    },
    "accent-hover": {
      "$value": "#FE8019",
      "$description": "Pressed / printed gold."
    },
    "highlight": {
      "$value": "#D79921",
      "$description": "Hover / on-dark accent gold."
    },
    "black": {
      "$value": "#282828",
      "$description": "Navy-900 \u2014 deepest."
    },
    "ink": {
      "$value": "#EBDBB2",
      "$description": "Body text on dark \u2014 high contrast."
    },
    "chapter-slab": {
      "$value": "#1D2021",
      "$description": "Deepest contrast band (gruvbox bg-hard) \u2014 chapter dividers sit on this; lighter than the base canvas so the divider reads."
    },
    "graphite": {
      "$value": "#D5C4A1",
      "$description": "Secondary text."
    },
    "steel": {
      "$value": "#A89984",
      "$description": "Tertiary / muted labels."
    },
    "silver": {
      "$value": "#928374",
      "$description": "Muted text on dark / soft labels."
    },
    "fog": {
      "$value": "#3C3836",
      "$description": "Warm hairlines on light."
    },
    "paper": {
      "$value": "#282828",
      "$description": "Warm paper \u2014 page on light."
    },
    "paper-2": {
      "$value": "#3C3836",
      "$description": "Raised surface on light."
    },
    "off-white": {
      "$value": "#EBDBB2",
      "$description": "Body text on dark."
    },
    "off-white-2": {
      "$value": "#928374",
      "$description": "Muted text on dark."
    },
    "rule-dark": {
      "$value": "#504945",
      "$description": "Hairlines on dark."
    },
    "navy-800": {
      "$value": "#1D2021",
      "$description": "Surface on dark."
    },
    "navy-700": {
      "$value": "#282828",
      "$description": "Raised surface on dark."
    },
    "navy-600": {
      "$value": "#3C3836",
      "$description": "Gem mid-facet."
    },
    "navy-500": {
      "$value": "#504945",
      "$description": "Gem upper-facet."
    },
    "navy-400": {
      "$value": "#665C54",
      "$description": "Gem highlight."
    },
    "navy-300": {
      "$value": "#928374",
      "$description": "Lifted on dark."
    },
    "navy-200": {
      "$value": "#928374",
      "$description": "Muted on dark."
    },
    "navy-100": {
      "$value": "#D5C4A1",
      "$description": "Soft divider on light."
    },
    "white": {
      "$value": "#FBF1C7"
    },
    "severity-low": {
      "$value": "#b8bb26",
      "$description": "Risk severity / status: low \u2014 palette-derived."
    },
    "severity-medium": {
      "$value": "#fabd2f",
      "$description": "Risk severity / status: medium \u2014 palette-derived."
    },
    "severity-high": {
      "$value": "#fb4934",
      "$description": "Risk severity / status: high \u2014 palette-derived."
    },
    "status-done": {
      "$value": "#b8bb26",
      "$description": "Status: done \u2014 alias of severity-low."
    },
    "status-current": {
      "$value": "#fabd2f",
      "$description": "Status: in progress \u2014 alias of severity-medium."
    },
    "status-next": {
      "$value": "#928374",
      "$description": "Status: not yet started \u2014 muted neutral."
    }
  },
  "font-family": {
    "$type": "fontFamily",
    "display": {
      "$value": [
        "Noto Sans",
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ]
    },
    "body": {
      "$value": [
        "Noto Sans",
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ]
    },
    "mono": {
      "$value": [
        "Noto Sans Mono",
        "ui-monospace",
        "Menlo",
        "monospace"
      ]
    }
  },
  "font-weight": {
