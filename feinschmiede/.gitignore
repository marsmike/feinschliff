# feinschmiede — repo-size discipline (mirrors the feinschliff convention).
# Vendored wheels, build intermediates, and the bin/ launcher's bootstrap venv
# are all regenerable and stay out of git. Phase 3 (PyPI) removes the wheels.

# Vendored offline wheelhouses (rebuild with each plugin's build-wheels.sh)
*/wheels/

# Build + debug intermediates (mirror of the .debug discipline)
.debug/
*/.debug/
*/dist/
*/build/

# Any stray bootstrap venv
*/venv/
venv/
