{
  "$schema": "https://schemas.designtokens.org/draft-2/format.json",
  "$description": "Feinschliff. — eponymous default brand pack. Navy ramp + warm paper + single gold accent. Bauhaus register. Noto Sans. MIT.",
  "color": {
    "$type": "color",
    "accent":       { "$value": "#C9A24A", "$description": "Primary gold — the only accent. Use sparingly." },
    "accent-hover": { "$value": "#8A6F2E", "$description": "Pressed / printed gold." },
    "highlight":    { "$value": "#E4C27A", "$description": "Hover / on-dark accent gold." },
    "black":        { "$value": "#0B1A33", "$description": "Navy-900 — deepest." },
    "ink":          { "$value": "#0B1A33", "$description": "Body ink on light = navy-900." },
    "chapter-slab": { "$value": "#0B1A33", "$description": "Deepest contrast band for chapter dividers. In light brands = ink; in dark brands override to the brand's canvas-deeper neutral." },
    "graphite":     { "$value": "#2D3A52", "$description": "Secondary text." },
    "steel":        { "$value": "#5A6478", "$description": "Tertiary / muted labels." },
    "silver":       { "$value": "#A9BCD6", "$description": "Muted text on dark / soft labels." },
    "chart-series-1": { "$value": "#C9A24A", "$description": "Categorical chart series 1 — gold." },
    "chart-series-2": { "$value": "#3A5B8C", "$description": "Categorical chart series 2 — blue." },
    "chart-series-3": { "$value": "#3F8553", "$description": "Categorical chart series 3 — green." },
    "chart-series-4": { "$value": "#A8442A", "$description": "Categorical chart series 4 — terracotta." },
    "chart-series-5": { "$value": "#5A6478", "$description": "Categorical chart series 5 — slate." },
    "chart-series-6": { "$value": "#6E8BB6", "$description": "Categorical chart series 6 — light blue." },
    "fog":          { "$value": "#D6D1C2", "$description": "Warm hairlines on light." },
    "paper":        { "$value": "#FAF8F3", "$description": "Warm paper — page on light." },
    "paper-2":      { "$value": "#F4F1E8", "$description": "Raised surface on light." },
    "off-white":    { "$value": "#F0ECE4", "$description": "Body text on dark." },
    "off-white-2":  { "$value": "#D9D3C5", "$description": "Muted text on dark." },
    "rule-dark":    { "$value": "#1F3056", "$description": "Hairlines on dark." },
    "navy-800":     { "$value": "#0F2040", "$description": "Surface on dark." },
    "navy-700":     { "$value": "#162A4A", "$description": "Raised surface on dark." },
    "navy-600":     { "$value": "#1E3258", "$description": "Gem mid-facet." },
    "navy-500":     { "$value": "#2D4770", "$description": "Gem upper-facet." },
    "navy-400":     { "$value": "#3A5B8C", "$description": "Gem highlight." },
    "navy-300":     { "$value": "#6E8BB6", "$description": "Lifted on dark." },
    "navy-200":     { "$value": "#A9BCD6", "$description": "Muted on dark." },
    "navy-100":     { "$value": "#D6E0EE", "$description": "Soft divider on light." },
    "white":        { "$value": "#FFFFFF" },
    "severity-low":    { "$value": "#3F8553", "$description": "Risk severity / status: low — restful green, harmonized with the navy ramp." },
    "severity-medium": { "$value": "#C9A24A", "$description": "Risk severity / status: medium — reuses accent gold." },
    "severity-high":   { "$value": "#A8442A", "$description": "Risk severity / status: high — desaturated rust, not pure red." },
    "status-done":     { "$value": "#3F8553", "$description": "Status: done — same green as severity-low." },
    "status-current":  { "$value": "#C9A24A", "$description": "Status: in progress — accent gold." },
    "status-next":     { "$value": "#5A6478", "$description": "Status: not yet started — steel grey." }
  },
  "font-family": {
    "$type": "fontFamily",
    "display": { "$value": ["Noto Sans", "Helvetica Neue", "Arial", "sans-serif"] },
    "body":    { "$value": ["Noto Sans", "Helvetica Neue", "Arial", "sans-serif"] },
    "mono":    { "$value": ["Noto Sans Mono", "ui-monospace", "Menlo", "monospace"] }
  },
  "font-weight": {
    "$type": "fontWeight",
    "light":   { "$value": 300 },
    "regular": { "$value": 400 },
    "medium":  { "$value": 500 },
    "semibold":{ "$value": 600 },
    "bold":    { "$value": 700 },
    "black":   { "$value": 900 }
  },
  "font-size": {
    "$type": "dimension",
    "$description": "Sizes match the shared 1920x1080 baseline.",
    "display":     { "$value": "160px" },
    "display-xl":  { "$value": "200px" },
    "huge":        { "$value": "120px" },
    "slide-title": { "$value": "37px" },
    "title-l":     { "$value": "80px" },
    "sub":         { "$value": "44px" },
    "body":        { "$value": "26px" },
    "eyebrow":     { "$value": "18px" },
    "footer":      { "$value": "16px" },
    "pgmeta":      { "$value": "18px" },
    "kpi-value":   { "$value": "120px" },
    "kpi-unit":    { "$value": "40px" },
    "kpi-key":     { "$value": "16px" },
    "kpi-delta":   { "$value": "18px" },
    "act-title":   { "$value": "56px" },
    "act-kicker":  { "$value": "18px" },
    "tracker":     { "$value": "16px" },
    "h-idx":       { "$value": "16px" },
    "h-hd":        { "$value": "32px" },
    "h-li":        { "$value": "22px" },
    "lede":        { "$value": "44px" },
    "col-num":     { "$value": "14px" },
    "col-title":   { "$value": "36px" },
    "col-title-q": { "$value": "28px" },
    "col-body":    { "$value": "22px" },
    "btn":         { "$value": "22px" },
    "chip":        { "$value": "16px" },
    "bar-label":   { "$value": "28px" },
    "bar-num":     { "$value": "22px" },
    "quote":       { "$value": "84px" },
    "quote-attr":  { "$value": "20px" },
    "bignum":      { "$value": "320px" },
    "agenda-num":  { "$value": "18px" },
    "agenda-t":    { "$value": "28px" },
    "agenda-d":    { "$value": "20px" }
  },
  "slide": {
    "$type": "dimension",
    "width":  { "$value": "1920px" },
    "height": { "$value": "1080px" },
    "padding-x": { "$value": "100px" },
    "padding-y-top":    { "$value": "100px" },
    "padding-y-bottom": { "$value": "80px" }
  },
  "$image_provider": { "kind": "unsplash" },
  "asset_sources": {
    "$description": "Where this brand pulls images/icons from. Each source has a kind: 'static' (catalog-bundled, sha-pinned) or 'search' (BYO-key API, e.g. Unsplash, Iconify). See references/asset-sources-spec.md.",
    "default": {
      "kind": "unsplash",
      "$description": "Unsplash search-backed provider — UNSPLASH_ACCESS_KEY must be set in the environment."
    }
  },
  "typography": {
    "display_tracking_curve": {
      "32": -0.005,
      "56": -0.015,
      "96": -0.025,
      "160": -0.035
    },
    "tnum_slot_keys": ["kpi_value", "axis_tick", "table_cell", "change_pct", "year", "count"]
  },
  "picture_treatment": "desat(0.3)",
  "locale": "en",
  "chart": {
    "chrome": "minimal",
    "axis_color_role": "fog",
    "legend_threshold": 4
  }
}
