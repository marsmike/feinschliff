#!/usr/bin/env bash
# feinschliff-builder launcher — the reusable "a plugin exposes a CLI" pattern.
# Requires bash. First run provisions a self-contained venv from bundled wheels
# (offline), then execs the real CLI; later runs just exec it. This plugin bundles
# the feinschliff + feinschmiede wheels too, so its Python `import feinschliff`
# resolves in its own venv (it is the office sub-family, Python-coupled by design).
# Toolkit layouts/brands come from the installed feinschliff plugin via the
# engine's installed-plugin discovery scan (feinschliff is a declared dependency).
set -euo pipefail

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-"$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"}"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-"${XDG_DATA_HOME:-$HOME/.local/share}/feinschmiede/feinschliff-builder"}"

VENV="$DATA_DIR/venv"
WHEELS="$PLUGIN_ROOT/wheels"
CLI="$VENV/bin/feinschliff-builder"
READY="$VENV/.feinschliff-builder-ready"

_BOOTSTRAPPING=0
_cleanup() { if [[ "$_BOOTSTRAPPING" -eq 1 && ! -f "$READY" ]]; then rm -rf "$VENV"; fi; }
trap _cleanup EXIT

_have_wheels() {
  [[ -d "$WHEELS" ]] || return 1
  local w
  for w in "$WHEELS"/*.whl; do [[ -e "$w" ]] && return 0; done
  return 1
}

_wheelhouse_sig() {
  { for w in "$WHEELS"/*.whl; do
      [[ -e "$w" ]] && printf '%s %s\n' "${w##*/}" "$(wc -c <"$w")"
    done | sort; } | cksum | awk '{print $1}'
}

_build_wheels_from_source() {
  # A marketplace/git install ships no wheels (gitignored). Build from the bundled
  # source on first run — needs uv + network. PyPI (Phase 3) replaces this.
  [[ -f "$PLUGIN_ROOT/build-wheels.sh" ]] || return 1
  command -v uv >/dev/null 2>&1 || return 1
  echo "feinschliff-builder: no prebuilt wheels — building from bundled source (first run; needs network)…" >&2
  bash "$PLUGIN_ROOT/build-wheels.sh" >&2
}

_bootstrap() {
  local sig="$1"
  if ! _have_wheels; then
    echo "feinschliff-builder: no bundled wheels at $WHEELS and could not build them (need uv + network)." >&2
    echo "feinschliff-builder: run build-wheels.sh in the plugin directory to populate them." >&2
    exit 1
  fi

  mkdir -p "$DATA_DIR"
  exec 9>"$DATA_DIR/.bootstrap.lock" || true
  if command -v flock >/dev/null 2>&1; then flock 9 || true; fi
  if [[ -f "$READY" && "$(cat "$READY" 2>/dev/null)" == "$sig" ]]; then
    exec 9>&-
    return 0
  fi

  echo "feinschliff-builder: first run — provisioning venv at $VENV (offline, from bundled wheels)…" >&2
  _BOOTSTRAPPING=1
  rm -rf "$VENV"

  local pyver=""
  [[ -f "$WHEELS/.python-version" ]] && pyver="$(cat "$WHEELS/.python-version")"

  if command -v uv >/dev/null 2>&1; then
    uv venv ${pyver:+--python "$pyver"} "$VENV" >&2
    uv pip install --reinstall --python "$VENV/bin/python" --no-index --find-links "$WHEELS" feinschliff-builder >&2
  else
    local py=""
    [[ -n "$pyver" ]] && py="$(command -v "python$pyver" || true)"
    [[ -z "$py" ]] && py="$(command -v python3 || true)"
    if [[ -z "$py" ]]; then
      echo "feinschliff-builder: need 'uv' or 'python3' (with venv support); neither was found." >&2
      exit 1
    fi
    "$py" -m venv "$VENV" >&2
    if ! "$VENV/bin/python" -m pip --version >/dev/null 2>&1; then
      "$VENV/bin/python" -m ensurepip --upgrade >&2 || {
        echo "feinschliff-builder: the venv has no pip and ensurepip failed — install 'uv' or python3-venv." >&2
        exit 1
      }
    fi
    "$VENV/bin/python" -m pip install --force-reinstall --no-index --find-links "$WHEELS" feinschliff-builder >&2
  fi

  printf '%s\n' "$sig" > "$READY"
  _BOOTSTRAPPING=0
  exec 9>&-
}

# #6: build the wheelhouse from bundled source on a fresh marketplace install.
if ! _have_wheels && [[ ! -f "$READY" ]]; then
  _build_wheels_from_source || true
fi

SIG="$(_wheelhouse_sig)"
if [[ ! -f "$READY" || "$(cat "$READY" 2>/dev/null)" != "$SIG" ]]; then
  _bootstrap "$SIG"
fi
exec "$CLI" "$@"
