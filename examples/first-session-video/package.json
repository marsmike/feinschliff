{
  "name": "first-session-video",
  "version": "1.0.0",
  "description": "RAISE Module 3 — first Claude Code session, rendered from .cast via Remotion.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "remotion preview src/index.ts",
    "render": "remotion render src/index.ts Main out/first-session.mp4 --concurrency 1",
    "still": "remotion still src/index.ts Main out/still.png --frame=1500",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "4.0.460",
    "@xterm/headless": "^5.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "4.0.440"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.0.0"
  }
}
