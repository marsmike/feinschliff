[0.030849, "o", "\u001b[6D\u001b[21B\r\u001b[1C\u001b[18A\u001b[38;5;246mwriting-skills\u001b[22Csuperpowers\u001b[2CUse\u001b[1Cwhen creating new skills, editing \u001b[38;5;153mexi\u001b[38;5;246mstin\u001b[2Cskills, o\u001b[1C verifying skills\r\u001b[36C\u001b[1Bwork before deployment\u001b[39m\u001b[K\r\u001b[1C\u001b[1B\u001b[38;5;246mskill-creator\u001b[22C(skill-cr\u001b[1Cato\u001b[1C) Create new skills,\u001b[1Cmod\u001b[1Cfy\u001b[1Cand im\u001b[1Cr\u001b[1Cve \u001b[38;5;153mexi\u001b[38;5;246msting skills, and measure skill\r\u001b[1B\u001b[39m                                    \u001b[38;5;246mperformance.\u001b[1CUs\u001b[1C when users want to create a skill from scratch,\u001b[1Cedit, or optimize an \u001b[38;5;153mexi\u001b[38;5;246m\u2026\r\u001b[1B/using-git-worktrees                (superpowers) Use when starting feature work that needs isolation from current workspace\r\u001b[1B\u001b[39m                                    \u001b[38;5;246mor b\u001b[1Cfore executing implementation plans - ensur\u001b[1Cs \u001b[1Cn isolated workspac\u001b[2C\u001b[38;5;153mexi\u001b[38;5;246mst\u001b[1C via nativ\u2026\r\u001b[1B/claude-api                         Build, debug, and optimize Claude API / Anthropic SDK apps. Apps built with this skill\r\u001b[1B\u001b[39m                                    \u001b[38;5;246mshould include prompt caching. Also handles migrating \u001b[38;5;153mexi\u001b[38;5;246msting Claude API code between Cl\u2026\r\u001b[36C\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[K\r\u001b[36C\u001b[1B\u001b[K\r\u001b[1B\u001b[K\r\u001b[36C\u001b[1B\u001b[K\r\u001b[1B\u001b[K\r\u001b[36C\u001b[1B\u001b[K\r\u001b[1B\u001b[K\r\u001b[36C\u001b[1B\u001b[K\r\r\n\r\n\u001b[6C\u001b[21A"]
