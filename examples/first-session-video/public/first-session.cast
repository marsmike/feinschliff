[0.200671, "o", "\u001b[2D\u001b[3B\r\u001b[4A  \u001b[1m4cb8f23 - split ringbuf into header + impl\u001b[22m: Extracted the struct definition, constant, and function declarations from the \u001b[38;5;153m.c\u001b[39m\u001b[K\r\u001b[1B  file\u001b[1Cinto\u001b[1Ca\u001b[1Cnew\u001b[1C\u001b[38;5;153mringbuf.h\u001b[1C\u001b[39mheader\u001b[1Cto\u001b[1Cseparate\u001b[1Cthe\u001b[1Cinterface\u001b[1Cfrom\u001b[1Cthe\u001b[1Cimplementation.\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;174m*\u001b[1CWhisking\u2026 \u001b[38;5;246m(22s \u00b7 \u2193\u001b[39m \u001b[38;5;246m1.0k tokens)\u001b[39m\u001b[K\r\r\n\r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\r\n\u001b[38;5;246m\u276f \u001b[39m \r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u250