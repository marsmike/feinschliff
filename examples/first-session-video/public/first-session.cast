[0.4, "o", "\u001b[2D\u001b[3B\r\u001b[4A  The change modified the buffer-full check from \u001b[38;5;153mif (next == rb->tail)\u001b[39m to \u001b[38;5;153mif (rb->head == rb->tail)\u001b[39m, but this inverts the logic:\u001b[K\r\u001b[1B  \u001b[38;5;153mhead == tail\u001b[1C\u001b[39mis\u001b[1Cthe\u001b[1Ccondition\u001b[1Cfor\u001b[1Can\u001b[1C\u001b[1mempty\u001b[1C\u001b[22mbuffer,\u001b[1Cnot\u001b[1Ca\u001b[1Cfull\u001b[1Cone.\u001b[1CThis\u001b[1Cmeans\u001b[1Cthe\u001b[1Cringbuffer\u001b[1Cwill\u001b[1Cnow\u001b[1Creject\u001b[1Cpushes\u001b[1Cwhen\u001b[1Cit's\r\u001b[1B  empty and allow overwrites when it's actually full (when \u001b[38;5;153m(head + 1) % capacity == tail\u001b[39m).\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\r\n\u001b[38;5;246m\u276f \u001b[39m \r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u250