[0.020076, "o", "\u001b[5D\u001b[21B\r\u001b[2C\u001b[18A\u001b[38;5;153mx\u001b[35C\u001b[38;5;246me\r\u001b[54C\u001b[1Be\u001b[6C\u001b[38;5;153mex\r\u001b[2C\u001b[1Bx\u001b[38;5;246mp\u001b[32C\u001b[38;5;153mEx\u001b[38;5;246mport the\u001b[1Ccurrent conversation to a file or clipboard\r\u001b[2C\u001b[1B\u001b[38;5;153mx\u001b[38;5;246mcalidraw\u001b[25C(\u001b[38;5;153mex\u001b[38;5;246mcalidraw) C\u001b[2Ca\u001b[1Ce Excalidraw diagram JSON fi\u001b[1Ces from DSL - Use when creating diagrams\r\u001b[1B\u001b[39m                                    \u001b[38;5;246mfor workflows, archite\u001b[1Ctures, or concepts\u001b[39m\u001b[K\r\u001b[1B\u001b[38;5;246m/\u001b[38;5;153mex\u001b[38;5;246mecuting-plans                    (superpowers) Use when you have a written implementation plan to \u001b[38;5;153mex\u001b[38;5;246mecute in a separate\r\u001b[1B\u001b[39m                                    \u001b[38;5;246msessio\u001b[1C with\u001b[1Crevi\u001b[1Cw ch\u001b[1Cckpoints\u001b[39m\u001b[K\r\u001b[1B\u001b[38;5;246m/brainstorming                      (superpowers) You MUST use this before any creative work - creating features, building\r\u001b[1B\u001b[39m                                    \u001b[38;5;246mcom\u001b[1Conents, adding fu\u001b[1Cctionality,\u001b[1Co\u001b[1C modifying b\u001b[1Chavior.\u001b[1C\u001b[38;5;153mEx\u001b[38;5;246mplores user intent, requir\u001b[1Cmen\u2026\r\u001b[1B/subagent-driven-development        (superpo\u001b[1Cers) Use \u001b[1Chen \u001b[38;5;153mex\u001b[38;5;246mecuting implementation plans with independent tasks in the\r\u001b[1B\u001b[39m                                    \u001b[38;5;246mcurrent se\u001b[1Csion\u001b[39m\u001b[K\r\u001b[1C\u001b[1B\u001b[38;5;246mupstream-plugin\u001b[21Cupstreamer) Use when\u001b[1Cupstre\u001b[1Cming \u001b[38;5;153mex\u001b[1C\u001b[38;5;246merimental\u001b[1Cplugins from genai-grimoire to\u001b[39m\u001b[K\r\u001b[36C\u001b[1B\u001b[38;5;246mgenai-sw-cookbook. Handles ver\u001