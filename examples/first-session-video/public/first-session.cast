[0.00709, "o", "\u001b[4D\u001b[21B\r\u001b[1C\u001b[19A\u001b[38;5;153mexit   \u001b[28CExit the CLI\u001b[39m\u001b[K\r\u001b[1B\u001b[38;5;246m/\u001b[38;5;153me\u001b[38;5;246mxtend                             (f\u001b[38;5;153me\u001b[38;5;246minschliff) Add a new layout to the active brand's catalog from a screenshot, brief,\u001b[39m\u001b[K\r\u001b[1B                                    \u001b[38;5;246mHTML, or .pptx. Us\u001b[38;5;153me\u001b[38;5;246m when \u001b[1Cx\u001b[1Cending a br\u001b[2Cd\u001b[1Cpack \u2014 in v2 this is a thin wrapper over /comp\u2026\r\u001b[1B/\u001b[38;5;153me\u001b[38;5;246mffort                             S\u001b[38;5;153me\u001b[38;5;246mt effort level for model usage\u001b[39m\u001b[K\r\u001b[1C\u001b[1B\u001b[38;5;153me\u001b[38;5;246mxport       \u001b[22C\u001b[38;5;153mE\u001b[38;5;246mxport th\u001b[1C current co\u001b[1Cversation\u001b[1Cto a file\u001b[1Cor clipboard\u001b[39m\u001b[K\r\u001b[1B\u001b[38;5;246m/\u001b[38;5;153me\u001b[38;5;246mxcalidraw                         (\u001b[38;5;153me\u001b[38;5;246mx\u001b[1Calidraw) Create Excalidraw diagram JSON files from DSL - Use when creating diagrams\r\u001b[1B\u001b[39m                                    \u001b[38;5;246mfor workflows, archit\u001b[38;5;153me\u001b[38;5;246mctures, or\u001b[1Cconc\u001b[1Cpts\u001b[39m\u001b[K\r\u001b[1B\u001b[38;5;246m/\u001b[38;5;153me\u001b[38;5;246mlevenlabs                         (\u001b[38;5;153me\u001b[38;5;246mlevenlab\u001b[1C) Convert text to speech with ElevenLabs. Use when generating speech audio or\r\u001b[1B\u001b[39m                                    \u001b[38;5;246mbrowsing voic\u001b[38;5;153me\u001b[38;5;246ms.\u001b[39m\u001b[K\r\u001b[1B\u001b[38;5;246m/\u001b[38;5;153me\u001b[38;5;246mxecuting-plans                    (s\u001b[1Cp\u001b[38;5;153me\u001b[38;5;246mrpowers) Use when you have a\u001b[1Cwritt\u001b[1Cn implementation\u001b[1Cplan to execute\u001b[1Cin\u001b[1Ca separ\u001b[1Cte\u001b[39m\u001b[K\r\u001b[1B                                    \u001b[38;5;246ms\u001b[38;5;153me\u001b[38;5;246mssio\u001b[1C \u001b[1Cith review checkpoints\r\u001b[1C\u001b[1Bsp\u001b[38;5;153me\u001b[38;5;246mak \u001b[29C(\u001b[38;5;153me\u001b[38;5;246mlev\u001b[1Cnlabs)\u001b[1CC\u001b[2Cvert text to speech using ElevenLabs and play it. Usage: /speak <text>\r\u001b[1C\u001b[1Br\u001b[1Cgflow   \u001b[25C(ragflow) RAGFlow CLI\u001b[1Cfor s\u001b[38;5;153me\u001b[38;5;246marching production knowledge bases. Use for C++ development,\r\u001b[1B\u001b[39m                                    \u001b[38;5;153me\u001b[38;5;246mmbedded\u001b[1Csystems, UI frameworks, research papers, datasheets, and technical documentation\u2026\r\u001b[2C\u001b[1Brainstorming\u001b[22C(\u001b[1Cup\u001b[38;5;153me\u001b[38;5;246mrpowers) You MUST use this befor\u001b[1C any crea\u001b[1Cive work - creating features, building\r\u001b[1B\u001b[39m                                    \u001b[38;5;246mcompon\u001b[38;5;153me\u001b[38;5;246mnts,\u001b[1Cadding functionality, or modifying behavior.\u001b[1CExplores\u001b[1Cuser\u001b[1Cintent, r\u001b[1Cqu\u001b[1Cremen\u2026\r\u001b[1B/writing-plans                      (sup\u001b[38;5;153me\u001b[38;5;246mrpowers) Use when you have a spec or requirements for a multi-step task, before\r\u001b[1B\u001b[39m                                    \u001b[38;5;246mtouching c\u001b[1Cd\u001b[38;5;153me\u001b[39m\u001b[K\r\u001b[1B\u001b[K\r\r\n\u001b[4C\u001b[21A"]
