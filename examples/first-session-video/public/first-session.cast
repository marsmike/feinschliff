[0.023628, "o", "\u001b[3D\u001b[3B\r\u001b[1A\u001b[38;5;153m/ragflow                            (ragflow) RAGFlow CLI for searching production knowledge bases. Use for C++ development,\u001b[39m\r\r\n\u001b[36C\u001b[38;5;153membedded\u001b[1Csystems,\u001b[1CUI\u001b[1Cframeworks,\u001b[1Cresearch\u001b[1Cpapers,\u001b[1Cdatasheets,\u001b[1Cand\u001b[1Ctechnical\u001b[1Cdocumentation\u2026\u001b[39m\r\r\n\u001b[38;5;246m/brainstorming\u001b[22C(superpowers)\u001b[1CYou\u001b[1CMUST\u001b[1Cuse\u001b[1Cthis\u001b[1Cbefore\u001b[1Cany\u001b[1Ccreative\u001b[1Cwork\u001b[1C-\u001b[1Ccreating\u001b[1Cfeatures,\u001b[1Cbuilding\u001b[39m\r\r\n\u001b[36C\u001b[38;5;246mcomponents,\u001b[1Cadding\u001b[1Cfunctionality,\u001b[1Cor\u001b[1Cmodifying\u001b[1Cbehavior.\u001b[1CExplores\u001b[1Cuser\u001b[1Cintent,\u001b[1Crequiremen\u2026\u001b[39m\r\r\n\u001b[38;5;246m/writing-plans\u001b[22C(superpowers)\u001b[1CUse\u001b[1Cwhen\u001b[1Cyou\u001b[1Chave\u001b[1Ca\u001b[1Cspec\u001b[1Cor\u001b[1Crequirements\u001b[1Cfor\u001b[1Ca\u001b[1Cmulti-step\u001b[1Ctask,\u001b[1Cbefore\u001b[39m\r\r\n\u001b[36C\u001b[38;5;246mtouching\u001b[1Ccode\u001b[39m\r\r\n\u001b[38;5;246m/subagent-driven-development\u001b[8C(superpowers)\u001b[1CUse\u001b[1Cwhen\u001b[1Cexecuting\u001b[1Cimplementation\u001b[1Cplans\u001b[1Cwith\u001b[1Cindependent\u001b[1Ctasks\u001b[1Cin\u001b[1Cthe\u001b[39m\r\r\n\u001b[36C\u001b[38;5;246mcurrent\u001b[1Csession\u001b[39m\r\r\n\u001b[38;5;246m/deck\u001b[31C(feinschliff)\u001b[1CBuild\u001b[1Cor\u001b[1Cpolish\u001b[1Ca\u001b[1Cbrand-compliant\u001b[1CPowerPoint\u001b[1Cdeck\u001b[1Cusing\u001b[1Cthe\u001b[1Cactive\u001b[1Cbrand's\u001b[39m\r\r\n\u001b[36C\u001b[38;5;246mBaukasten.\u001b[1CUse\u001b[1Cwhen\u001b[1Cthe\u001b[1Cuser\u001b[1Casks\u001b[1Cto\u001b[1Ccreate\u001b[1Ca\u001b[1Cdeck,\u001b[1Cmake\u001b[1Ca\u001b[1Cpresentation,\u001b[1Cor\u001b[1Cpolish\u001b[1Ca\u001b[1Croug\u2026\u001b[39m\r\r\n\u001b[38;5;246m/add-dir\u001b[28CAdd\u001b[1Ca\u001b[1Cnew\u001b[1Cworking\u001b[1Cdirectory\u001b[39m\r\r\n\u001b[38;5;246m/agents\u001b[29CManage\u001b[1Cagent\u001b[1Cconfigurations\u001b[39m\r\r\n\u001b[38;5;246m/background\u001b[25CContinue\u001b[1Cthis\u001b[1Csession\u001b[1Cin\u001b[1Cthe\u001b[1Cbackground\u001b[1Cand\u001b[1Cfree\u001b[1Cthe\u001b[1Cterminal\u001b[39m\r\r\n\u001b[38;5;246m/branch\u001b[29CCreate\u001b[1Ca\u001b[1Cbranch\u001b[1Cof\u001b[1Cthe\u001b[1Ccurrent\u001b[1Cconversation\u001b[1Cat\u001b[1Cthis\u001b[1Cpoint\u001b[39m\r\r\n\u001b[38;5;246m/btw\u001b[32CAsk\u001b[1Ca\u001b[1Cquick\u001b[1Cside\u001b[1Cquestion\u001b[1Cwithout\u001b[1Cinterrupting\u001b[1Cthe\u001b[1Cmain\u001b[1Cconversation\u001b[39m\r\r\n\u001b[38;5;246m/clear\u001b[30CStart\u001b[1Ca\u001b[1Cnew\u001b[1Csession\u001b[1Cwith\u001b[1Cempty\u001b[1Ccontext;\u001b[1Cprevious\u001b[1Csession\u001b[1Cstays\u001b[1Con\u001b[1Cdisk\u001b[1C(resumable\u001b[1Cwith\u001b[39m\r\r\n\u001b[36C\u001b[38;5;246m/resume)\u001b[39m\r\r\n\u001b[38;5;246m/color\u001b[30CSet\u001b[1Cthe\u001b[1Cprompt\u001b[1Cbar\u001b[1Ccolor\u001b[1Cfor\u001b[1Cthis\u001b[1Csession\u001b[39m\r\r\n\u001b[38;5;246m/compact\u001b[28CFree\u001b[1Cup\u001b[1Ccontext\u001b[1Cby\u001b[1Csummarizing\u001b[1Cthe\u001b[1Cconversation\u001b[1Cso\u001b[1Cfar\u001b[39m\r\r\n\u001b[3C\u001b[21A"]
