{
  "$schema": "https://schemas.designtokens.org/draft-2/format.json",
  "$description": "Shapes — port of Microsoft's free 'The power of communication' (Shapes design) presentation template (powerpoint.cloud.microsoft). Scattered decorative geometry and a big blue title circle on white. Palette + fonts + slide dims are seeded by brand_decompile_all.py from the source theme; extends feinschliff for everything else.",
  "color": {
    "$type": "color",
    "theme-dk1": {
      "$value": "#000000",
      "$description": "Source theme dk1."
    },
    "theme-lt1": {
      "$value": "#FFFFFF",
      "$description": "Source theme lt1."
    },
    "theme-dk2": {
      "$value": "#FFF8F4",
      "$description": "Source theme dk2."
    },
    "theme-lt2": {
      "$value": "#E8E8E8",
      "$description": "Source theme lt2."
    },
    "theme-accent1": {
      "$value": "#EE7660",
      "$description": "Source theme accent1."
    },
    "theme-accent2": {
      "$value": "#4D90EF",
      "$description": "Source theme accent2."
    },
    "theme-accent3": {
      "$value": "#5B5160",
      "$description": "Source theme accent3."
    },
    "theme-accent4": {
      "$value": "#2BC2B4",
      "$description": "Source theme accent4."
    },
    "theme-accent5": {
      "$value": "#C097F8",
      "$description": "Source theme accent5."
    },
    "theme-accent6": {
      "$value": "#FF9413",
      "$description": "Source theme accent6."
    },
    "theme-hlink": {
      "$value": "#467886",
      "$description": "Source theme hlink."
    },
    "theme-folHlink": {
      "$value": "#96607D",
      "$description": "Source theme folHlink."
    },
    "ink": {
      "$value": "#000000",
      "$description": "Body/title ink — source theme dk1."
    },
    "black": {
      "$value": "#000000",
      "$description": "Display / deepest — source theme dk1."
    },
    "paper": {
      "$value": "#FFFFFF",
      "$description": "Canvas on light — source theme lt1."
    },
    "white": {
      "$value": "#FFFFFF"
    }
  },
  "slide": {
    "$type": "dimension",
    "width_emu": {
      "$value": "12192000",
      "$description": "Source PPTX slide width in EMU — drives emitter scaling."
    },
    "height_emu": {
      "$value": "6858000",
      "$description": "Source PPTX slide height in EMU — drives emitter scaling."
    },
    "left-rail": {
      "$value": "132",
      "$description": "87% of decompiled text nodes sit at x=132 (Shapes Microsoft template native padding)."
    },
    "rail-snap-enabled": {
      "$value": "1",
      "$description": "Engage the snap-to-rail post-pass."
    },
    "rail-snap-threshold": {
      "$value": "10",
      "$description": "Tight threshold — catches per-brand drift, leaves toolkit layouts at x=100 alone (diff > threshold)."
    }
  },
  "font-family": {
    "$type": "fontFamily",
    "display": {
      "$value": [
        "Tw Cen MT",
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ],
      "$description": "Source theme majorFont: Tw Cen MT"
    },
    "body": {
      "$value": [
        "Avenir Next LT Pro Light",
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ],
      "$description": "Source theme minorFont: Avenir Next LT Pro Light"
    }
  }
}
