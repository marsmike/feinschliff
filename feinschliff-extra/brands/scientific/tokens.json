{
  "$schema": "https://schemas.designtokens.org/draft-2/format.json",
  "$description": "Scientific — port of Microsoft's free 'Scientific discovery' pitch-deck template (powerpoint.cloud.microsoft). Condensed display type (Daytona), Posterama accents, Courier New data callouts. Palette + fonts + slide dims are seeded by brand_decompile_all.py from the source theme; extends feinschliff for everything else.",
  "color": {
    "$type": "color",
    "theme-dk1": {
      "$value": "#000000",
      "$description": "Source theme dk1."
    },
    "theme-lt1": {
      "$value": "#FFFFFF",
      "$description": "Source theme lt1."
    },
    "theme-dk2": {
      "$value": "#44546A",
      "$description": "Source theme dk2."
    },
    "theme-lt2": {
      "$value": "#E7E6E6",
      "$description": "Source theme lt2."
    },
    "theme-accent1": {
      "$value": "#96D3ED",
      "$description": "Source theme accent1."
    },
    "theme-accent2": {
      "$value": "#C7DBE1",
      "$description": "Source theme accent2."
    },
    "theme-accent3": {
      "$value": "#688EBD",
      "$description": "Source theme accent3."
    },
    "theme-accent4": {
      "$value": "#BCE5DD",
      "$description": "Source theme accent4."
    },
    "theme-accent5": {
      "$value": "#66DDCC",
      "$description": "Source theme accent5."
    },
    "theme-accent6": {
      "$value": "#E0CE61",
      "$description": "Source theme accent6."
    },
    "theme-hlink": {
      "$value": "#0563C1",
      "$description": "Source theme hlink."
    },
    "theme-folHlink": {
      "$value": "#954F72",
      "$description": "Source theme folHlink."
    },
    "ink": {
      "$value": "#000000",
      "$description": "Body/title ink — source theme dk1."
    },
    "black": {
      "$value": "#000000",
      "$description": "Display / deepest — source theme dk1."
    },
    "paper": {
      "$value": "#FFFFFF",
      "$description": "Canvas on light — source theme lt1."
    },
    "white": {
      "$value": "#FFFFFF"
    }
  },
  "slide": {
    "$type": "dimension",
    "width_emu": {
      "$value": "12192000",
      "$description": "Source PPTX slide width in EMU — drives emitter scaling."
    },
    "height_emu": {
      "$value": "6858000",
      "$description": "Source PPTX slide height in EMU — drives emitter scaling."
    }
  },
  "font-family": {
    "$type": "fontFamily",
    "display": {
      "$value": [
        "Posterama",
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ],
      "$description": "Source theme majorFont: Posterama"
    },
    "body": {
      "$value": [
        "Daytona Condensed Light",
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ],
      "$description": "Source theme minorFont: Daytona Condensed Light"
    }
  }
}
