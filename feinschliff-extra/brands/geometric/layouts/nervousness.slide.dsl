role: chapter-opener
ideal_count: [1, 2]
data_band: none
comparison: false
when_not_to_use: [role=content-columns, role=data-quantity, role=data-comparison]
family: framing
fixed_chrome: true
chrome_note: 'carries native source chrome verbatim: 2 illustration'
slide_index: 4
slots:
