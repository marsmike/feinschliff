{
  "$schema": "https://schemas.designtokens.org/draft-2/format.json",
  "$description": "Geometric — port of Microsoft's free 'The power of communication' (Geometric design) presentation template (powerpoint.cloud.microsoft). Bold geometric color blocks, Arial Black display over Sabon Next LT. Palette + fonts + slide dims are seeded by brand_decompile_all.py from the source theme; extends feinschliff for everything else.",
  "color": {
    "$type": "color",
    "theme-dk1": {
      "$value": "#000000",
      "$description": "Source theme dk1."
    },
    "theme-lt1": {
      "$value": "#FDFAF6",
      "$description": "Source theme lt1."
    },
    "theme-dk2": {
      "$value": "#44546A",
      "$description": "Source theme dk2."
    },
    "theme-lt2": {
      "$value": "#E7E6E6",
      "$description": "Source theme lt2."
    },
    "theme-accent1": {
      "$value": "#F5CDCE",
      "$description": "Source theme accent1."
    },
    "theme-accent2": {
      "$value": "#DE8C8C",
      "$description": "Source theme accent2."
    },
    "theme-accent3": {
      "$value": "#AAC3E8",
      "$description": "Source theme accent3."
    },
    "theme-accent4": {
      "$value": "#D2D592",
      "$description": "Source theme accent4."
    },
    "theme-accent5": {
      "$value": "#CCBE89",
      "$description": "Source theme accent5."
    },
    "theme-accent6": {
      "$value": "#1F2C8F",
      "$description": "Source theme accent6."
    },
    "theme-hlink": {
      "$value": "#1F2C8F",
      "$description": "Source theme hlink."
    },
    "theme-folHlink": {
      "$value": "#AAC3E9",
      "$description": "Source theme folHlink."
    },
    "ink": {
      "$value": "#000000",
      "$description": "Body/title ink — source theme dk1."
    },
    "black": {
      "$value": "#000000",
      "$description": "Display / deepest — source theme dk1."
    },
    "paper": {
      "$value": "#FDFAF6",
      "$description": "Canvas on light — source theme lt1."
    },
    "white": {
      "$value": "#FDFAF6"
    }
  },
  "slide": {
    "$type": "dimension",
    "width_emu": {
      "$value": "12192000",
      "$description": "Source PPTX slide width in EMU — drives emitter scaling."
    },
    "height_emu": {
      "$value": "6858000",
      "$description": "Source PPTX slide height in EMU — drives emitter scaling."
    },
    "left-rail": {
      "$value": "144",
      "$description": "100% of decompiled text nodes sit at x=144 (Geometric Microsoft template native padding)."
    },
    "rail-snap-enabled": {
      "$value": "1",
      "$description": "Engage the snap-to-rail post-pass."
    },
    "rail-snap-threshold": {
      "$value": "10",
      "$description": "Tight threshold — catches per-brand drift, leaves toolkit layouts at x=100 alone (diff > threshold)."
    }
  },
  "font-family": {
    "$type": "fontFamily",
    "display": {
      "$value": [
        "Arial Black",
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ],
      "$description": "Source theme majorFont: Arial Black"
    },
    "body": {
      "$value": [
        "Sabon Next LT",
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ],
      "$description": "Source theme minorFont: Sabon Next LT"
    }
  }
}
