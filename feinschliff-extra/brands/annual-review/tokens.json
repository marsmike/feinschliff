{
  "$schema": "https://schemas.designtokens.org/draft-2/format.json",
  "$description": "Annual Review — port of Microsoft's free 'Annual Review' presentation template (powerpoint.cloud.microsoft). Two pastel full-bleed section panels (warm yellow + pale blue) alternate against black ink and white content slides; heavy Arial Nova display. Extends feinschliff for sizes, slide dims, chart + typography config.",
  "color": {
    "$type": "color",
    "accent": {
      "$value": "#4495A2",
      "$description": "Teal — the saturated brand accent (chart series, links, small emphasis). Theme accent3."
    },
    "accent-hover": {
      "$value": "#37757F",
      "$description": "Pressed / printed teal."
    },
    "highlight": {
      "$value": "#A9D4DB",
      "$description": "Pale blue — lifted accent / on-panel highlight."
    },
    "panel-blue": {
      "$value": "#A9D4DB",
      "$description": "Signature pale-blue full-bleed SECTION panel (agenda, growth-chart, quote, summary). Theme accent1."
    },
    "panel-yellow": {
      "$value": "#FBE284",
      "$description": "Signature warm-yellow full-bleed SECTION panel (cover, growth-table, timeline). Theme accent2."
    },
    "ink": {
      "$value": "#000000",
      "$description": "All body + title text — pure black, the template's only text color (on white AND on pastel panels)."
    },
    "black": {
      "$value": "#000000",
      "$description": "Display/title + thick rules — pure black."
    },
    "chapter-slab": {
      "$value": "#000000",
      "$description": "Chapter-divider band = ink (this brand divides with pastel panels, not a dark slab)."
    },
    "graphite": {
      "$value": "#2B2B2B",
      "$description": "Secondary text."
    },
    "steel": {
      "$value": "#5E5E5E",
      "$description": "Tertiary / muted labels (footer meta)."
    },
    "silver": {
      "$value": "#9A9A9A",
      "$description": "Muted text / soft labels."
    },
    "fog": {
      "$value": "#E4E4E4",
      "$description": "Warm-grey hairlines / table rules on light. Theme dk2."
    },
    "paper": {
      "$value": "#FFFFFF",
      "$description": "White content canvas (introduction, team, goals, thank-you)."
    },
    "paper-2": {
      "$value": "#F4F4F4",
      "$description": "Raised surface / photo placeholder fill."
    },
    "off-white": {
      "$value": "#FFFFFF",
      "$description": "Panel-contrast / text-on-dark = white."
    },
    "off-white-2": {
      "$value": "#E4E4E4",
      "$description": "Muted on dark."
    },
    "rule-dark": {
      "$value": "#333333",
      "$description": "Hairlines on dark."
    },
    "white": {
      "$value": "#FFFFFF"
    },
    "chart-series-1": {
      "$value": "#A9D4DB",
      "$description": "Categorical chart series 1 — pale blue."
    },
    "chart-series-2": {
      "$value": "#4495A2",
      "$description": "Categorical chart series 2 — teal."
    },
    "chart-series-3": {
      "$value": "#000000",
      "$description": "Categorical chart series 3 — black."
    },
    "chart-series-4": {
      "$value": "#FBE284",
      "$description": "Categorical chart series 4 — yellow."
    },
    "chart-series-5": {
      "$value": "#AA5881",
      "$description": "Categorical chart series 5 — mauve. Theme accent4."
    },
    "chart-series-6": {
      "$value": "#E06742",
      "$description": "Categorical chart series 6 — terracotta. Theme accent5."
    },
    "severity-low": {
      "$value": "#7CA655",
      "$description": "Status low — olive green. Theme lt2."
    },
    "severity-medium": {
      "$value": "#F9D448",
      "$description": "Status medium — golden. Theme accent6."
    },
    "severity-high": {
      "$value": "#E06742",
      "$description": "Status high — terracotta. Theme accent5."
    },
    "status-done": {
      "$value": "#7CA655",
      "$description": "Status done — alias of severity-low."
    },
    "status-current": {
      "$value": "#F9D448",
      "$description": "Status in progress — alias of severity-medium."
    },
    "status-next": {
      "$value": "#9A9A9A",
      "$description": "Status not started — muted neutral."
    },
    "theme-dk1": {
      "$value": "#000000",
      "$description": "Source theme dk1."
    },
    "theme-lt1": {
      "$value": "#FFFFFF",
      "$description": "Source theme lt1."
    },
    "theme-dk2": {
      "$value": "#E4E4E4",
      "$description": "Source theme dk2."
    },
    "theme-lt2": {
      "$value": "#7CA655",
      "$description": "Source theme lt2."
    },
    "theme-accent1": {
      "$value": "#A9D4DB",
      "$description": "Source theme accent1."
    },
    "theme-accent2": {
      "$value": "#FBE284",
      "$description": "Source theme accent2."
    },
    "theme-accent3": {
      "$value": "#4495A2",
      "$description": "Source theme accent3."
    },
    "theme-accent4": {
      "$value": "#AA5881",
      "$description": "Source theme accent4."
    },
    "theme-accent5": {
      "$value": "#E06742",
      "$description": "Source theme accent5."
    },
    "theme-accent6": {
      "$value": "#F9D448",
      "$description": "Source theme accent6."
    },
    "theme-hlink": {
      "$value": "#4495A2",
      "$description": "Source theme hlink."
    },
    "theme-folHlink": {
      "$value": "#AA5881",
      "$description": "Source theme folHlink."
    }
  },
  "font-family": {
    "$type": "fontFamily",
    "display": {
      "$value": [
        "Arial Nova",
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ],
      "$description": "Source theme majorFont: Arial Nova"
    },
    "body": {
      "$value": [
        "Arial Nova",
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ],
      "$description": "Source theme minorFont: Arial Nova"
    },
    "mono": {
      "$value": [
        "Consolas",
        "SF Mono",
        "Menlo",
        "ui-monospace",
        "monospace"
      ]
    }
  },
  "slide": {
    "$type": "dimension",
    "width_emu": {
      "$value": "12192000",
      "$description": "Source PPTX slide width in EMU — drives emitter scaling."
    },
    "height_emu": {
      "$value": "6858000",
      "$description": "Source PPTX slide height in EMU — drives emitter scaling."
    }
  }
