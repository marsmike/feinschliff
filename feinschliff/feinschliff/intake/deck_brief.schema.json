{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "feinschliff/deck-brief/v1",
  "title": "Deck Brief",
  "type": "object",
  "required": ["schema_version", "goal", "audience", "deck_type"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "goal": {
      "type": "string",
      "enum": ["decision", "buy-in", "awareness", "training", "status", "inspire"]
    },
    "audience": {
      "type": "string",
      "enum": ["exec", "technical", "mixed", "external-customer", "external-investor"]
    },
    "audience_prior": {
      "type": "string",
      "enum": ["none", "some", "expert"]
    },
    "call_to_action": {
      "type": "string",
      "minLength": 1
    },
    "deck_type": {
      "type": "string",
      "enum": [
        "pitch",
        "data-story",
        "status-update",
        "training",
        "company-intro",
        "proposal",
        "retrospective",
        "all-hands",
        "board-update"
      ]
    },
    "visual_style": {
      "type": "string",
      "enum": [
        "rich-imagery",
        "process-flow",
        "org-hierarchy",
        "data-dense",
        "concept-text",
        "mixed"
      ]
    },
    "length_hint": {
      "type": "string",
      "enum": ["short", "standard", "long"]
    },
    "must_include": {
      "type": "array",
      "items": {"type": "string"}
    },
    "tone": {
      "type": "string",
      "enum": ["formal", "confident-direct", "warm", "playful", "brand-default"]
    },
    "constraints": {
      "type": "object",
      "properties": {
        "time_to_present_min": {"type": "integer", "minimum": 1},
        "no_charts": {"type": "boolean"}
      }
    }
  }
}
