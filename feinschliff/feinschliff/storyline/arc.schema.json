{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "feinschliff/storyline/arc/v1",
  "title": "Arc Schema",
  "type": "object",
  "required": ["deck_type", "source", "acts"],
  "additionalProperties": false,
  "properties": {
    "deck_type": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "acts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "desc"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "required": {
            "type": "boolean",
            "default": true
          },
          "desc": {
            "type": "string",
            "minLength": 1
          },
          "position": {
            "type": "string",
            "enum": ["opening", "middle", "late", "closing", "any"],
            "default": "any"
          }
        }
      }
    }
  }
}
