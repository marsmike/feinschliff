{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "feinschliff/storyline/commitment/v1",
  "title": "Commitment Document",
  "type": "object",
  "required": ["deck_type", "thesis", "key_moves"],
  "additionalProperties": false,
  "properties": {
    "deck_type": {
      "type": "string",
      "minLength": 1
    },
    "thesis": {
      "type": "string",
      "minLength": 1
    },
    "key_moves": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "source"],
        "additionalProperties": false,
        "properties": {
          "claim": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "arc_check": {
      "type": "string",
      "enum": ["pass", "warn", "fail"]
    }
  }
}
