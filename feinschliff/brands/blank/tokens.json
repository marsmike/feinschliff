{
  "$schema": "https://schemas.designtokens.org/draft-2/format.json",
  "$description": "Blank — neutral white super-design parent. All chromatic colours from feinschliff are remapped to grayscale; severity and status stay semantic. Brands that want their own identity to dominate (corporate white-label packs) extend `blank` instead of `feinschliff` and override only the keys that matter.",
  "color": {
    "$type": "color",
    "accent": {
      "$value": "#1A1A1A",
      "$description": "Primary gold — the only accent. Use sparingly."
    },
    "accent-hover": {
      "$value": "#0A0A0A",
      "$description": "Pressed / printed gold."
    },
    "highlight": {
      "$value": "#555555",
      "$description": "Hover / on-dark accent gold."
    },
    "black": {
      "$value": "#000000",
      "$description": "Navy-900 — deepest."
    },
    "ink": {
      "$value": "#111111",
      "$description": "Body ink on light = navy-900."
    },
    "chapter-slab": {
      "$value": "#FFFFFF",
      "$description": "Deepest contrast band for chapter dividers. In light brands = ink; in dark brands override to the brand's canvas-deeper neutral."
    },
    "graphite": {
      "$value": "#444444",
      "$description": "Secondary text."
    },
    "steel": {
      "$value": "#7A7A7A",
      "$description": "Tertiary / muted labels."
    },
    "silver": {
      "$value": "#B5B5B5",
      "$description": "Muted text on dark / soft labels."
    },
    "fog": {
      "$value": "#E5E5E5",
      "$description": "Warm hairlines on light."
    },
    "paper": {
      "$value": "#FFFFFF",
      "$description": "Warm paper — page on light."
    },
    "paper-2": {
      "$value": "#F5F5F5",
      "$description": "Raised surface on light."
    },
    "off-white": {
      "$value": "#EFEFEF",
      "$description": "Body text on dark."
    },
    "off-white-2": {
      "$value": "#CFCFCF",
      "$description": "Muted text on dark."
    },
    "rule-dark": {
      "$value": "#1F1F1F",
      "$description": "Hairlines on dark."
    },
    "navy-800": {
      "$value": "#2A2A2A",
      "$description": "Surface on dark."
    },
    "navy-700": {
      "$value": "#3A3A3A",
      "$description": "Raised surface on dark."
    },
    "navy-600": {
      "$value": "#505050",
      "$description": "Gem mid-facet."
    },
    "navy-500": {
      "$value": "#6B6B6B",
      "$description": "Gem upper-facet."
    },
    "navy-400": {
      "$value": "#888888",
      "$description": "Gem highlight."
    },
    "navy-300": {
      "$value": "#A8A8A8",
      "$description": "Lifted on dark."
    },
    "navy-200": {
      "$value": "#C8C8C8",
      "$description": "Muted on dark."
    },
    "navy-100": {
      "$value": "#E5E5E5",
      "$description": "Soft divider on light."
    },
    "white": {
      "$value": "#FFFFFF"
    },
    "severity-low": {
      "$value": "#4A8753",
      "$description": "Risk severity / status: low — restful green, harmonized with the navy ramp."
    },
    "severity-medium": {
      "$value": "#C09030",
      "$description": "Risk severity / status: medium — reuses accent gold."
    },
    "severity-high": {
      "$value": "#A04532",
      "$description": "Risk severity / status: high — desaturated rust, not pure red."
    },
    "status-done": {
      "$value": "#4A8753",
      "$description": "Status: done — same green as severity-low."
    },
    "status-current": {
      "$value": "#C09030",
      "$description": "Status: in progress — accent gold."
    },
    "status-next": {
      "$value": "#6B6B6B",
      "$description": "Status: not yet started — steel grey."
    }
  },
  "font-family": {
    "$type": "fontFamily",
    "display": {
      "$value": [
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ]
    },
    "body": {
      "$value": [
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ]
    },
    "mono": {
      "$value": [
        "Noto Sans Mono",
        "ui-monospace",
        "Menlo",
        "monospace"
      ]
    }
  },
  "font-weight": {
    "$type": "fontWeight",
    "light": {
      "$value": 300
    },
    "regular": {
      "$value": 400
    },
    "medium": {
      "$value": 500
    },
    "semibold": {
      "$value": 600
    },
    "bold": {
      "$value": 700
    },
    "black": {
      "$value": 900
    }
  },
  "font-size": {
    "$type": "dimension",
    "$description": "Sizes match the shared 1920x1080 baseline.",
    "display": {
      "$value": "160px"
    },
    "display-xl": {
      "$value": "200px"
    },
    "huge": {
      "$value": "120px"
    },
    "slide-title": {
      "$value": "37px"
    },
    "title-l": {
      "$value": "80px"
    },
    "sub": {
      "$value": "44px"
    },
    "body": {
      "$value": "26px"
    },
    "eyebrow": {
      "$value": "18px"
    },
    "footer": {
      "$value": "16px"
    },
    "pgmeta": {
      "$value": "18px"
    },
    "kpi-value": {
      "$value": "120px"
    },
    "kpi-unit": {
      "$value": "40px"
    },
    "kpi-key": {
      "$value": "16px"
    },
    "kpi-delta": {
      "$value": "18px"
    },
    "act-title": {
      "$value": "56px"
    },
    "act-kicker": {
      "$value": "18px"
    },
    "tracker": {
      "$value": "16px"
    },
    "h-idx": {
      "$value": "16px"
    },
    "h-hd": {
      "$value": "32px"
    },
    "h-li": {
      "$value": "22px"
    },
    "lede": {
      "$value": "44px"
    },
    "col-num": {
      "$value": "14px"
    },
    "col-title": {
      "$value": "36px"
    },
    "col-title-q": {
      "$value": "28px"
    },
    "col-body": {
      "$value": "22px"
    },
    "btn": {
      "$value": "22px"
    },
    "chip": {
      "$value": "16px"
    },
    "bar-label": {
      "$value": "28px"
    },
    "bar-num": {
      "$value": "22px"
    },
    "quote": {
      "$value": "84px"
    },
    "quote-attr": {
      "$value": "20px"
    },
    "bignum": {
      "$value": "320px"
    },
    "agenda-num": {
      "$value": "18px"
    },
    "agenda-t": {
      "$value": "28px"
    },
    "agenda-d": {
      "$value": "20px"
    }
  },
  "slide": {
    "$type": "dimension",
    "width": {
      "$value": "1920px"
    },
    "height": {
      "$value": "1080px"
    },
    "padding-x": {
      "$value": "100px"
    },
    "padding-y-top": {
      "$value": "100px"
    },
    "padding-y-bottom": {
      "$value": "80px"
    }
  },
  "asset_sources": {
    "$description": "Where this brand pulls images/icons from. Each source has a kind: 'static' (catalog-bundled, sha-pinned) or 'search' (BYO-key API, e.g. Unsplash, Iconify). See references/asset-sources-spec.md.",
    "default": {
      "kind": "static",
      "$description": "Default search-free behaviour: only assets shipped under brands/feinschliff/assets/ are available. Override per-brand to enable a search-source."
    }
  },
  "typography": {
    "display_tracking_curve": {
      "32": -0.005,
      "56": -0.015,
      "96": -0.025,
      "160": -0.035
    },
    "tnum_slot_keys": [
      "kpi_value",
      "axis_tick",
      "table_cell",
      "change_pct",
      "year",
      "count"
    ]
  },
  "picture_treatment": "desat(0.3)",
  "locale": "en",
  "chart": {
    "chrome": "minimal",
    "axis_color_role": "fog",
    "legend_threshold": 4
  }
}
