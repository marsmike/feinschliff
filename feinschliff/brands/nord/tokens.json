{
  "$schema": "https://schemas.designtokens.org/draft-2/format.json",
  "$description": "Nord \u2014 Arctic, north-bluish color palette designed for clear and minimal interfaces. Upstream nordtheme/nord (MIT).",
  "color": {
    "$type": "color",
    "accent": {
      "$value": "#88C0D0",
      "$description": "Primary gold \u2014 the only accent. Use sparingly."
    },
    "accent-hover": {
      "$value": "#81A1C1",
      "$description": "Pressed / printed gold."
    },
    "highlight": {
      "$value": "#5E81AC",
      "$description": "Hover / on-dark accent gold."
    },
    "black": {
      "$value": "#2E3440",
      "$description": "Navy-900 \u2014 deepest."
    },
    "ink": {
      "$value": "#ECEFF4",
      "$description": "Body text on dark \u2014 high contrast."
    },
    "chapter-slab": {
      "$value": "#2E3440",
      "$description": "Polar Night nord0 \u2014 deepest contrast band for chapter dividers."
    },
    "graphite": {
      "$value": "#D8DEE9",
      "$description": "Secondary text."
    },
    "steel": {
      "$value": "#81A1C1",
      "$description": "Tertiary / muted labels."
    },
    "silver": {
      "$value": "#4C566A",
