{
  "$schema": "https://schemas.designtokens.org/draft-2/format.json",
  "$description": "Claude — warm cream canvas + coral accent + serif editorial register. Derived from claude/DESIGN.md (Anthropic Claude product surface). MIT.",
  "color": {
    "$type": "color",
    "accent":       { "$value": "#CC785C", "$description": "Coral — the Anthropic warm coral, primary CTA fill." },
    "accent-hover": { "$value": "#A9583E", "$description": "Coral pressed / active." },
    "highlight":    { "$value": "#E8A55A", "$description": "Companion warm amber — small inline highlights, badges." },
    "black":        { "$value": "#141413", "$description": "Ink — warm dark, slightly off-pure-black." },
    "ink":          { "$value": "#141413", "$description": "Body ink on cream = same warm dark." },
    "graphite":     { "$value": "#252523", "$description": "Body strong — emphasized paragraphs, lead text." },
    "steel":        { "$value": "#6C6A64", "$description": "Muted — sub-headings, breadcrumbs, secondary text." },
    "silver":       { "$value": "#8E8B82", "$description": "Muted soft — captions, fine-print." },
    "fog":          { "$value": "#E6DFD8", "$description": "Hairline border on cream surfaces." },
    "paper":        { "$value": "#FAF9F5", "$description": "Canvas — tinted cream, the brand-defining warm white." },
    "paper-2":      { "$value": "#EFE9DE", "$description": "Surface card — feature cards, content cards." },
    "off-white":    { "$value": "#FAF9F5", "$description": "On-dark text — cream-tinted white that echoes the canvas." },
    "off-white-2":  { "$value": "#A09D96", "$description": "On-dark soft — footer body text, secondary labels." },
    "rule-dark":    { "$value": "#252320", "$description": "Hairlines on dark surfaces." },
    "surface-dark":           { "$value": "#181715", "$description": "Code editors, model showcase cards, footer." },
    "surface-dark-elevated":  { "$value": "#252320", "$description": "Elevated cards inside dark bands." },
    "surface-dark-soft":      { "$value": "#1F1E1B", "$description": "Code block backgrounds inside dark cards." },
    "surface-soft":           { "$value": "#F5F0E8", "$description": "Section dividers, soft band backgrounds." },
    "surface-cream-strong":   { "$value": "#E8E0D2", "$description": "Strongest cream — selected tabs, emphasized bands." },
    "accent-teal":  { "$value": "#5DB8A6", "$description": "Secondary product accent — status dots, terminal indicators." },
    "success":      { "$value": "#5DB872", "$description": "Status success." },
    "warning":      { "$value": "#D4A017", "$description": "Status warning." },
    "error":        { "$value": "#C64545", "$description": "Status error." },
    "white":        { "$value": "#FFFFFF" },
    "severity-low":    { "$value": "#5DB872",  "$description": "Risk severity / status: low — palette-derived." },
    "severity-medium": { "$value": "#D4A017",  "$description": "Risk severity / status: medium — palette-derived." },
    "severity-high":   { "$value": "#C8553D", "$description": "Risk severity / status: high — palette-derived." },
    "status-done":     { "$value": "#5DB872",  "$description": "Status: done — alias of severity-low." },
    "status-current":  { "$value": "#D4A017",  "$description": "Status: in progress — alias of severity-medium." },
    "status-next":     { "$value": "#6B6360", "$description": "Status: not yet started — muted neutral." }
  },
  "font-family": {
    "$type": "fontFamily",
    "$description": "Editorial pairing — slab-serif display (Copernicus/EB Garamond) + humanist sans body (Inter). JetBrains Mono for code.",
    "display": { "$value": ["Copernicus", "Tiempos Headline", "EB Garamond", "Garamond", "Times New Roman", "serif"] },
    "body":    { "$value": ["StyreneB", "Inter", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "sans-serif"] },
    "mono":    { "$value": ["JetBrains Mono", "ui-monospace", "Menlo", "Consolas", "monospace"] }
  },
  "font-weight": {
    "$type": "fontWeight",
    "$description": "Display sizes use weight 400 (regular) per the Claude brief — serif at 700 reads as bombastic.",
    "light":   { "$value": 300 },
    "regular": { "$value": 400 },
    "medium":  { "$value": 500 },
    "semibold":{ "$value": 600 },
    "bold":    { "$value": 700 },
    "black":   { "$value": 900 }
  },
  "font-size": {
    "$type": "dimension",
    "$description": "Sizes match the shared 1920x1080 baseline.",
    "display":     { "$value": "160px" },
    "huge":        { "$value": "120px" },
    "slide-title": { "$value": "37px" },
    "sub":         { "$value": "44px" },
    "body":        { "$value": "26px" },
    "eyebrow":     { "$value": "18px" },
    "footer":      { "$value": "16px" },
    "pgmeta":      { "$value": "18px" },
    "kpi-value":   { "$value": "120px" },
    "kpi-unit":    { "$value": "40px" },
    "kpi-key":     { "$value": "16px" },
    "kpi-delta":   { "$value": "18px" },
    "col-num":     { "$value": "14px" },
    "col-title":   { "$value": "36px" },
    "col-body":    { "$value": "22px" },
    "btn":         { "$value": "22px" },
    "chip":        { "$value": "16px" },
    "bar-label":   { "$value": "28px" },
    "bar-num":     { "$value": "22px" },
    "quote":       { "$value": "84px" },
    "quote-attr":  { "$value": "20px" },
    "bignum":      { "$value": "320px" },
    "agenda-num":  { "$value": "18px" },
    "agenda-t":    { "$value": "28px" },
    "agenda-d":    { "$value": "20px" }
  },
  "radius": {
    "$type": "dimension",
    "$description": "Claude uses 8px on CTAs/buttons, 12px on content cards, 16px on hero containers. card defaults to 12.",
    "xs":   { "$value": "4px" },
    "sm":   { "$value": "6px" },
    "md":   { "$value": "8px" },
    "lg":   { "$value": "12px" },
    "xl":   { "$value": "16px" },
    "card": { "$value": "12px" },
    "pill": { "$value": "9999px" }
  },
  "slide": {
    "$type": "dimension",
    "width":  { "$value": "1920px" },
    "height": { "$value": "1080px" },
    "padding-x": { "$value": "100px" },
    "padding-y-top":    { "$value": "100px" },
    "padding-y-bottom": { "$value": "80px" }
  },
  "$image_provider": { "kind": "unsplash" }
}
