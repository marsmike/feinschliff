{
  "$schema": "https://schemas.designtokens.org/draft-2/format.json",
  "$description": "Solarized Dark — Ethan Schoonover's classic precision-engineered palette — warm yellows on cool teal-black. Upstream ethanschoonover.com/solarized (MIT).",
  "color": {
    "$type": "color",
    "accent": {
      "$value": "#B58900",
      "$description": "Primary gold — the only accent. Use sparingly."
    },
    "accent-hover": {
      "$value": "#CB4B16",
      "$description": "Pressed / printed gold."
    },
    "highlight": {
      "$value": "#2AA198",
      "$description": "Hover / on-dark accent gold."
    },
    "black": {
      "$value": "#002B36",
      "$description": "Navy-900 — deepest."
    },
    "ink": {
      "$value": "#002B36",
      "$description": "Body ink on light = navy-900."
    },
    "graphite": {
      "$value": "#073642",
      "$description": "Secondary text."
    },
    "steel": {
      "$value": "#586E75",
      "$description": "Tertiary / muted labels."
    },
    "silver": {
      "$value": "#839496",
      "$description": "Muted text on dark / soft labels."
    },
    "fog": {
      "$value": "#EEE8D5",
      "$description": "Warm hairlines on light."
    },
    "paper": {
      "$value": "#FDF6E3",
      "$description": "Warm paper — page on light."
    },
    "paper-2": {
      "$value": "#EEE8D5",
      "$description": "Raised surface on light."
    },
    "off-white": {
      "$value": "#EEE8D5",
      "$description": "Body text on dark."
    },
    "off-white-2": {
      "$value": "#93A1A1",
      "$description": "Muted text on dark."
    },
    "rule-dark": {
      "$value": "#586E75",
      "$description": "Hairlines on dark."
    },
    "navy-800": {
      "$value": "#002B36",
      "$description": "Surface on dark."
    },
    "navy-700": {
      "$value": "#073642",
      "$description": "Raised surface on dark."
    },
    "navy-600": {
      "$value": "#586E75",
      "$description": "Gem mid-facet."
    },
    "navy-500": {
      "$value": "#657B83",
      "$description": "Gem upper-facet."
    },
    "navy-400": {
      "$value": "#839496",
      "$description": "Gem highlight."
    },
    "navy-300": {
      "$value": "#93A1A1",
      "$description": "Lifted on dark."
    },
    "navy-200": {
      "$value": "#839496",
      "$description": "Muted on dark."
    },
    "navy-100": {
      "$value": "#EEE8D5",
      "$description": "Soft divider on light."
    },
    "white": {
      "$value": "#FDF6E3"
    },
    "severity-low":    { "$value": "#859900",  "$description": "Risk severity / status: low — palette-derived." },
    "severity-medium": { "$value": "#b58900",  "$description": "Risk severity / status: medium — palette-derived." },
    "severity-high":   { "$value": "#dc322f", "$description": "Risk severity / status: high — palette-derived." },
    "status-done":     { "$value": "#859900",  "$description": "Status: done — alias of severity-low." },
    "status-current":  { "$value": "#b58900",  "$description": "Status: in progress — alias of severity-medium." },
    "status-next":     { "$value": "#586e75", "$description": "Status: not yet started — muted neutral." }
  },
  "font-family": {
    "$type": "fontFamily",
    "display": {
      "$value": [
        "Noto Sans",
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ]
    },
    "body": {
      "$value": [
        "Noto Sans",
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ]
    },
    "mono": {
      "$value": [
        "Noto Sans Mono",
        "ui-monospace",
        "Menlo",
        "monospace"
      ]
    }
  },
  "font-weight": {
    "$type": "fontWeight",
    "light": {
      "$value": 300
    },
    "regular": {
      "$value": 400
    },
    "medium": {
      "$value": 500
    },
    "semibold": {
      "$value": 600
    },
    "bold": {
      "$value": 700
    },
    "black": {
      "$value": 900
    }
  },
  "font-size": {
    "$type": "dimension",
    "$description": "Sizes match the shared 1920x1080 baseline.",
    "display": {
      "$value": "160px"
    },
    "huge": {
      "$value": "120px"
    },
    "slide-title": {
      "$value": "37px"
    },
    "sub": {
      "$value": "44px"
    },
    "body": {
      "$value": "26px"
    },
    "eyebrow": {
      "$value": "18px"
    },
    "footer": {
      "$value": "16px"
    },
    "pgmeta": {
      "$value": "18px"
    },
    "kpi-value": {
      "$value": "120px"
    },
    "kpi-unit": {
      "$value": "40px"
    },
    "kpi-key": {
      "$value": "16px"
    },
    "kpi-delta": {
      "$value": "18px"
    },
    "col-num": {
      "$value": "14px"
    },
    "col-title": {
      "$value": "36px"
    },
    "col-body": {
      "$value": "22px"
    },
    "btn": {
      "$value": "22px"
    },
    "chip": {
      "$value": "16px"
    },
    "bar-label": {
      "$value": "28px"
    },
    "bar-num": {
      "$value": "22px"
    },
    "quote": {
      "$value": "84px"
    },
    "quote-attr": {
      "$value": "20px"
    },
    "bignum": {
      "$value": "320px"
    },
    "agenda-num": {
      "$value": "18px"
    },
    "agenda-t": {
      "$value": "28px"
    },
    "agenda-d": {
      "$value": "20px"
    }
  },
  "slide": {
    "$type": "dimension",
    "width": {
      "$value": "1920px"
    },
    "height": {
      "$value": "1080px"
    },
    "padding-x": {
      "$value": "100px"
    },
    "padding-y-top": {
      "$value": "100px"
    },
    "padding-y-bottom": {
      "$value": "80px"
    }
  }
}
