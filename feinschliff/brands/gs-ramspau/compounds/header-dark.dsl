# gs-ramspau header — dark-mode variant. Light wordmark + faded pgmeta
# on the ink/tief ground.

compound header-dark(pgmeta):
  text 120,80  style:wordmark color:off-white   maxwidth:420 maxheight:92 "GRUNDSCHULE\nRAMSPAU"
  text 1100,90 style:pgmeta   color:off-white-2 maxwidth:720 maxheight:32 "{{ pgmeta }}" align:right
