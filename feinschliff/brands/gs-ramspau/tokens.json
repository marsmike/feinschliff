{
  "$schema": "https://schemas.designtokens.org/draft-2/format.json",
  "$description": "Grundschule Ramspau — Schule im Grünen. Bespoke 8-layout pack. Wiese green + tief deep-ink + warm papier.",
  "color": {
    "$type": "color",
    "accent":       { "$value": "#9eb05c", "$description": "Wiese — primary green. Claim bar, accent rules, agenda numerals. Nudged from source #A8B86B to clear WCAG 2.0:1 on papier." },
    "accent-hover": { "$value": "#8a9c50", "$description": "Pressed wiese." },
    "highlight":    { "$value": "#c5d18d", "$description": "Lifted wiese for hover / on-dark accent." },
    "ink":          { "$value": "#1f1f1c", "$description": "Tinte — body text on light." },
    "black":        { "$value": "#3f4b2e", "$description": "Tief — deep-ink background, display title color." },
    "graphite":     { "$value": "#9a8f86", "$description": "Taupe — muted labels." },
    "steel":        { "$value": "#9a8f86", "$description": "Taupe (same — gs-ramspau has no separate steel)." },
    "silver":       { "$value": "#c8c1b8", "$description": "Lighter taupe." },
    "fog":          { "$value": "#dddcda", "$description": "Hairlines on light." },
    "paper":        { "$value": "#f6f3ec", "$description": "Papier — warm canvas on light." },
    "paper-2":      { "$value": "#ece7dc", "$description": "Body bg / photo placeholder fill." },
    "off-white":    { "$value": "#f6f3ec", "$description": "Papier (text on dark)." },
    "off-white-2":  { "$value": "#d9d3c5", "$description": "Muted text on dark." },
    "rule-dark":    { "$value": "#34362a", "$description": "Hairlines on tief." },
    "white":        { "$value": "#ffffff" },
    "severity-low":    { "$value": "#3F8553",  "$description": "Risk severity / status: low — palette-derived." },
    "severity-medium": { "$value": "#C9A24A",  "$description": "Risk severity / status: medium — palette-derived." },
    "severity-high":   { "$value": "#A8442A", "$description": "Risk severity / status: high — palette-derived." },
    "status-done":     { "$value": "#3F8553",  "$description": "Status: done — alias of severity-low." },
    "status-current":  { "$value": "#C9A24A",  "$description": "Status: in progress — alias of severity-medium." },
    "status-next":     { "$value": "#5A6478", "$description": "Status: not yet started — muted neutral." }
  },
  "font-family": {
    "$type": "fontFamily",
    "display": { "$value": ["Open Sans", "Helvetica Neue", "Arial", "sans-serif"] },
    "body":    { "$value": ["Open Sans", "Helvetica Neue", "Arial", "sans-serif"] },
    "mono":    { "$value": ["Consolas", "SF Mono", "Menlo", "ui-monospace", "monospace"] }
  }
}
