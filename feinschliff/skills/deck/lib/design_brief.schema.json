{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "feinschliff/design-brief/v1",
  "title": "Design Brief",
  "type": "object",
  "required": ["takeaway", "audience", "audience_notes", "frame", "frame_rationale", "hook", "red_line", "slides"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Self-identifying schema URI, e.g. 'feinschliff/design-brief/v1'."
    },
    "takeaway": {
      "type": "string",
      "description": "One-sentence top-of-pyramid — the single thing the audience should remember.",
      "minLength": 10,
      "maxLength": 200
    },
    "audience": {
      "type": "string",
      "enum": ["exec", "manager", "developer", "peer"]
    },
    "audience_notes": {
      "type": "string",
      "description": "Why this audience — what they care about, what loses them.",
      "minLength": 10,
      "maxLength": 400
    },
    "frame": {
      "type": "string",
      "enum": ["scqa", "pssr", "sparkline", "man-in-hole", "ppf", "pse", "kea", "abt"]
    },
    "frame_rationale": {
      "type": "string",
      "description": "Why this frame fits. Names the runner-up frame and why it was rejected.",
      "minLength": 10,
      "maxLength": 400
    },
    "hook": {
      "type": "object",
      "required": ["technique", "opener"],
      "additionalProperties": false,
      "properties": {
        "technique": {
          "type": "string",
          "enum": ["startling-stat", "provocative-question", "brief-story", "demonstration", "contrast"]
        },
        "opener": {
          "type": "string",
          "minLength": 5,
          "maxLength": 200,
          "description": "The actual opening line, ≤20 words."
        }
      }
    },
    "red_line": {
      "type": "string",
      "description": "The one-sentence story arc across the deck.",
      "minLength": 10,
      "maxLength": 300
    },
    "verbosity": {
      "type": "string",
      "enum": ["concise", "standard", "text-heavy"],
      "description": "Inferred at Step 1. Controls per-slide word budget: concise ~20w, standard ~40w, text-heavy ~60w."
    },
    "delivery": {
      "type": "string",
      "enum": ["live", "async", "both"],
      "description": "How the deck will be consumed: 'live' (projected/presented), 'async' (shared PDF/forwarded), or 'both'."
    },
    "delivery_mode": {
      "type": "string",
      "enum": ["in-person", "virtual", "hybrid"],
      "description": "Physical context of delivery. 'virtual' and 'hybrid' trigger the safe-zone rule (critical content in top 60% / centre 80%)."
    },
    "image_style": {
      "type": "string",
      "enum": ["photorealistic", "illustration", "abstract", "minimal", "data-viz", "none"],
      "description": "Visual style governing all image and illustration assets across the deck. Ensures cross-slide image consistency. Inferred from brief context or explicitly set by the user at Step 0."
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "maxItems": 40,
      "items": {
        "type": "object",
        "required": ["index", "role", "claim", "audience_fit"],
        "additionalProperties": false,
        "properties": {
          "index": {"type": "integer", "minimum": 0},
          "role": {
            "type": "string",
            "enum": ["hook", "context", "complication", "recommendation", "support", "evidence", "voice", "close"]
          },
          "claim": {
            "type": "string",
            "minLength": 5,
            "maxLength": 300,
            "description": "Full sentence with verb or number; not a topic noun."
          },
          "audience_fit": {
            "type": "string",
            "minLength": 5,
            "maxLength": 300,
            "description": "One-sentence note on what to emphasize / suppress for this audience."
          }
        }
      }
    }
  }
}
